server {
    server_name gw.appwizersolutions.com;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/nginx/sslcerts/public.pem; # managed by Certbot
    ssl_certificate_key /etc/nginx/sslcerts/private.key; # managed by Certbot
}

server {
    if ($host = gw.appwizersolutions.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name 3.111.221.156.nip.io;
    return 404; # managed by Certbot
}
